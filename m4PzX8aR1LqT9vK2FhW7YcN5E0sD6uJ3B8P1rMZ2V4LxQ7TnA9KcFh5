local a=Enum.KeyCode.X
local b=2e3
local c=1

local d=game:GetService("Players")
local e=game:GetService("UserInputService")
local f=game:GetService("RunService")
local g=game:GetService("StarterGui")

local h=d.LocalPlayer
local i=workspace.CurrentCamera

local function j(k,l)
    g:SetCore("SendNotification",{
        Title=k,
        Text=l,
        Duration=3
    })
end

j("Teleport Script by Memphis","Teleport em execução.\n🇽 (Teleport para o ponto de vista)")

local function m()
    local n=h.Character
    if not n then return end

    local o=n:FindFirstChild("HumanoidRootPart")
    if not o then return end

    local p=i.CFrame.Position
    local q=i.CFrame.LookVector * b

    local r=RaycastParams.new()
    r.FilterDescendantsInstances={n}
    r.FilterType=Enum.RaycastFilterType.Blacklist

    local s=workspace:Raycast(p,q,r)

    local t
    if s then
        t=s.Position + Vector3.new(0,3,0)
    else
        t=p + q
    end

    o.CFrame = CFrame.new(t)
    o.AssemblyLinearVelocity = Vector3.zero
    o.AssemblyAngularVelocity = Vector3.zero

    local u=0
    local v
    v = f.Heartbeat:Connect(function()
        if u >= c then
            v:Disconnect()
            return
        end
        o.AssemblyLinearVelocity = Vector3.zero
        o.AssemblyAngularVelocity = Vector3.zero
        u = u + 1
    end)
end

e.InputBegan:Connect(function(w,x)
    if x then return end
    if w.KeyCode == a then
        m()
    end
end)
